.history-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部导航 */
.header-section {
  background: white;
  padding: 48rpx 48rpx 32rpx;
  margin-bottom: 32rpx;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.search-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-icon {
  font-size: 32rpx;
  color: #666;
}

/* 筛选和统计 */
.filter-section {
  padding: 0 48rpx 32rpx;
}

.stats-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  text-align: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #0052D9;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.filter-tabs {
  display: flex;
  background: white;
  border-radius: 24rpx;
  padding: 8rpx;
  gap: 8rpx;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.filter-tab.active {
  background: #0052D9;
  color: white;
  font-weight: 500;
}

/* 主要内容 */
.main-content {
  padding: 0 48rpx 32rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-item {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
}

.record-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.record-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.record-icon.score-excellent {
  background: #f6ffed;
}

.record-icon.score-good {
  background: #f0f9ff;
}

.record-icon.score-average {
  background: #fff7ed;
}

.record-icon.score-poor {
  background: #fef2f2;
}

.icon {
  font-size: 40rpx;
  color: #666;
}

.record-details {
  flex: 1;
}

.record-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.record-score-section {
  font-size: 26rpx; /* 调大字号 */
  font-weight: 600; /* 加粗 */
  padding: 10rpx 20rpx; /* 增加内边距 */
  border-radius: 20rpx;
}

.record-score-section.score-excellent {
  background: #f6ffed;
  color: #52c41a;
}

.record-score-section.score-good {
  background: #f0f9ff;
  color: #0052D9;
}

.record-score-section.score-average {
  background: #fff7ed;
  color: #ff8a00;
}

.record-score-section.score-poor {
  background: #fef2f2;
  color: #e53e3e;
}

.record-summary {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1px solid #f0f0f0;
}

.delete-btn {
  background-color: transparent;
  color: #e64340;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0;
  margin: 0;
  border: none;
  line-height: 1.5;
  text-align: left;
}

.delete-btn::after {
  border: none;
}

.view-detail {
  font-size: 28rpx;
  color: #0052D9;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 48rpx;
}

.start-check-btn {
  width: 300rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  margin-top: 48rpx;
}

.load-more-btn {
  width: 300rpx;
}
