/* 上传页面样式 */
.upload-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部导航 */
.header-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 40rpx 60rpx;
  color: white;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
}

/* 主内容区域 */
.main-content {
  padding: 40rpx;
  margin-top: -40rpx;
}

/* 上传卡片 */
.upload-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.upload-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.upload-icon .icon {
  font-size: 40rpx;
}

.upload-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.upload-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
}

/* 上传区域 */
.upload-area {
  border: 3rpx dashed #ddd;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  background: #fafafa;
  transition: all 0.3s;
}

.upload-area:active {
  border-color: #0052D9;
  background: #f0f7ff;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.upload-icon-large {
  font-size: 80rpx;
  color: #999;
}

.upload-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.upload-subtext {
  font-size: 24rpx;
  color: #999;
}

.select-image-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

/* 确认按钮 */
.confirm-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: linear-gradient(135deg, #00a870 0%, #00c48c 100%);
}

/* 内容提取预览区域 */
.extraction-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.extraction-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.extraction-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.extraction-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-processing {
  color: #0052D9;
  font-size: 26rpx;
  font-weight: 500;
}

.status-completed {
  color: #00a870;
  font-size: 26rpx;
  font-weight: 500;
}

/* 处理状态提示 */
.processing-status {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
}

.status-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.status-icon {
  font-size: 32rpx;
  animation: spin 1s linear infinite;
}

.status-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 分段列表 */
.segments-preview {
  margin-bottom: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.segments-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.segments-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.segments-count {
  font-size: 24rpx;
  color: #666;
  background: #f0f7ff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.segments-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.segment-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border-left: 4rpx solid #0052D9;
  transition: all 0.3s ease;
}

.segment-item:hover {
  background: #f0f7ff;
  transform: translateX(4rpx);
}

.segment-number {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #0052D9 0%, #667eea 100%);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.segment-content {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-word;
}

/* 问题输入区域 */
.question-input-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.question-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.question-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.question-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.question-form {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.form-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
  box-sizing: border-box;
  resize: none;
}

.form-input:focus {
  border-color: #0052D9;
  background: white;
}

.question-input {
  min-height: 100rpx;
}

.answer-input {
  min-height: 100rpx;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

.analysis-section {
  margin-top: 20rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.analysis-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
}

/* 底部提示 */
.bottom-tips {
  text-align: center;
  padding: 40rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  background: white;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 正在进行的任务提示 */
.ongoing-task-section {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.ongoing-task-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.ongoing-task-icon {
  font-size: 24rpx;
  animation: pulse 2s infinite;
}

.ongoing-task-text {
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}

.return-task-btn {
  width: 100%;
  height: 60rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: white;
}

.return-task-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}
