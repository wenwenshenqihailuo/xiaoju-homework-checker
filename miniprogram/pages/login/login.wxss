.login-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部装饰 */
.header-decoration {
  height: 384rpx;
  background: linear-gradient(135deg, #0052D9 0%, #7B68EE 50%, #FF69B4 100%);
  position: relative;
  overflow: hidden;
}

.header-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  text-align: center;
  padding: 0 48rpx;
}

.app-icon {
  width: 128rpx;
  height: 128rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.icon {
  font-size: 64rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #E6F3FF;
}

/* 装饰圆圈 */
.decoration-circle {
  position: absolute;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.circle-1 {
  top: 80rpx;
  left: 80rpx;
  width: 128rpx;
  height: 128rpx;
}

.circle-2 {
  bottom: 80rpx;
  right: 80rpx;
  width: 96rpx;
  height: 96rpx;
}

.circle-3 {
  top: 50%;
  right: 128rpx;
  width: 80rpx;
  height: 80rpx;
}

/* 登录区域 */
.login-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 48rpx 64rpx;
  margin-top: -160rpx;
  position: relative;
  z-index: 20;
}

.login-card {
  background: white;
  border-radius: 48rpx;
  padding: 64rpx;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  max-width: 600rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 64rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  font-size: 32rpx;
  color: #666;
  display: block;
}

/* 登录按钮 */
.login-button-container {
  margin-bottom: 64rpx;
}

.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 24rpx;
  background: #07C160 !important;
  border: none !important;
}

.wechat-login-btn .wechat-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

/* 协议部分 */
.agreement-section {
  text-align: center;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.link-text {
  color: #0052D9;
}

/* 底部装饰 */
.footer-decoration {
  padding: 48rpx 48rpx 64rpx;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: #ccc;
  display: block;
}

.slogan-text {
  font-size: 24rpx;
  color: #ccc;
  display: block;
  margin-top: 8rpx;
}
